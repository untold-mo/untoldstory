# انسخ إلى .env.production وعدّل القيم قبل: npm run build
# أو مرّر المتغيرات في بيئة الـ CI

# عنوان API للواجهة (بدون سلاش أخيرة). عند البناء للإنتاج يُستخدم تلقائياً كأساس لمسارات OAuth
# (/api/integrations/auth/...) إن لم تضبط VITE_OAUTH_API_ORIGIN — سجّل نفس الـ redirect_uri في Meta/Google/LinkedIn على HTTPS.
# VITE_API_URL=https://api.your-new-domain.com

# اختياري: VITE_DATA_SOURCE=server — build الإنتاج يفترض السيرفر إن لم تضبط VITE_DATA_SOURCE=local عند التطوير

# عنوان الواجهة العام بالـ HTTPS (بدون سلاش أخيرة) — مطلوب إذا كان البروكسي/CDN يغيّر الـ Host
# VITE_PUBLIC_APP_URL=https://www.untoldstory.click

# إذا خادم الـ OAuth/API على نطاق مختلف عن الواجهة (اختياري)
# VITE_OAUTH_API_ORIGIN=https://api.your-new-domain.com

# Supabase مباشر — مطلوب لـ untoldstory.click
# VITE_USE_SUPABASE=1
# VITE_SUPABASE_URL=https://axkoidcmiqutdtcadfca.supabase.co
# VITE_SUPABASE_ANON_KEY=...
# ⚠️ لا تستخدم المشروع القديم hfbnysvmrqglccxswqfm (موقوف — egress)

# إذا رفعت التطبيق تحت مسار وليس على جذر الدومين (مثلاً public_html/myapp/)
# القيمة يجب أن تبدأ وتنتهي بـ /
# VITE_BASE_PATH=/myapp/
