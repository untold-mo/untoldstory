.lang-switcher.light .current-lang {
  background: #f5f5f5;
  color: #000;
}

.current-lang {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 6px 12px;
  border-radius: 30px;
}

.current-lang img {
  width: 22px;
  height: 22px;
  border-radius: 50%;
  object-fit: cover;
}

.arrow {
  font-size: 10px;
  margin-top: 2px;
}

