.lang-switcher.dark .current-lang {
  background: #111;
  color: #fff;
}

/* الوضع الفاتح (لو حبيت تغير) */
.lang-switcher.light .current-lang {
  background: #f5f5f5;
  color: #000;
}

.current-lang {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 6px 12px;
  border-radius: 30px;
}

.current-lang img {
  width: 22px;
  height: 22px;
  border-radius: 50%;
  object-fit: cover;
}

.arrow {
  font-size: 10px;
  margin-top: 2px;
}

/* الدروب داون */
.lang-dropdown {
  list-style: none;
  margin: 0px;
  padding: 6px 0;
  position: absolute;
  left: 0;
  background: #111;
  border-radius: 10px;
  box-shadow: 0 10px 30px rgba(0,0,0,.35);
  display: none;
  min-width: 140px;
  z-index: 9999;
}

.lang-dropdown li a {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 14px;
  color: #fff;
  text-decoration: none;
  font-size: 14px;
}

.lang-dropdown li a img {
  width: 22px;
  height: 22px;
  border-radius: 50%;
}

.lang-dropdown li a:hover {
  background: rgba(255,255,255,.08);
}

.lang-switcher:hover .lang-dropdown {
  display: block;
}
