# --- الواجهة (Vite): انسخ إلى .env.local في جذر المشروع ---
# راجع أيضاً: .env.local.example
VITE_API_URL=http://localhost:4000
VITE_OAUTH_API_ORIGIN=http://localhost:4000
VITE_DATA_SOURCE=server
# اختياري:
# VITE_PUBLIC_APP_URL=http://localhost:5173
# VITE_BASE_PATH=/

# --- الباكند (Express + Prisma): انسخ إلى api/.env ---
# راجع أيضاً: api/.env.example
# DATABASE_URL=
# DIRECT_URL=
# PORT=4000
# JWT_SECRET=
# JWT_EXPIRES_IN=7d
# ADMIN_API_KEY=
# CORS_ORIGINS=http://localhost:5173
