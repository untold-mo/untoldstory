# انسخ إلى .env.migrate في جذر المشروع (لا يُرفع على git)
#
# المصدر = المشروع الحالي (القديم)
# الهدف  = مشروع Supabase الجديد

# Direct connection — Settings → Database → Connection string → Direct (منفذ 5432)
OLD_DIRECT_URL="postgresql://postgres.OLD_REF:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres?sslmode=require"
NEW_DIRECT_URL="postgresql://postgres.NEW_REF:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres?sslmode=require"

# للتحقق بعد النقل (Settings → API)
NEW_SUPABASE_URL="https://NEW_REF.supabase.co"
NEW_SUPABASE_ANON_KEY="eyJ..."
NEW_SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# مطلوب لتشغيل النقل الفعلي
CONFIRM_MIGRATE=YES

# اختياري: إزالة صور avatar الضخمة (base64) من users أثناء النقل
STRIP_AVATAR_BASE64=1
