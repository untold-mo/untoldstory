# انسخ هذا الملف إلى .env.local في جذر المشروع (الواجهة Vite)
#
# تشغيل تلقائي للواجهة + API معاً (أمر واحد):
#   npm run dev:auto
# (يتطلّب ملف api/.env مع قاعدة بيانات — انسخ من api/.env.example)

# عنوان باك اند Express — التطوير المحلي الافتراضي في الكود: http://localhost:4000
VITE_API_URL=http://localhost:4000

# OAuth (ربط ليدز): الافتراضي = نفس أصل الواجهة؛ Vite يوجّه `/api/integrations` إلى Express (منفذ 4000) مع `npm run dev:auto`.
# اختياري: بروكسي آخر
# VITE_OAUTH_PROXY_TARGET=http://127.0.0.1:4000

# ——— ربط حقيقي (Meta / Google / LinkedIn): عيّن المفاتيح في api/.env (انظر backend/env.oauth.example)
# سجّل redirect_uri مثل: http://localhost:5173/api/integrations/auth/meta-facebook/callback
# وفي api/.env: OAUTH_PUBLIC_BASE_URL=http://localhost:5173

# بعد تشغيل مجلد api وبيانات حقيقية — إلزامي لو هتختبر موظفين وحسابات وتسجيل الدخول (Express):
# مهم جداً: لا تترك مسافة قبل اسم المتغير (مثلاً لا تكتب " VITE_DATA_SOURCE")
VITE_DATA_SOURCE=server

# عند إنشاء موظف من المالك (بريد + كلمة مرور 8+): يُستدعى /auth/v1/signup تلقائياً دون تبديل جلسة المالك.
# في لوحة Supabase → Authentication: فعّل Email provider و«Sign up»؛ للتجربة السريعة عطّل «Confirm email» أو فعّل Auto-confirm للمستخدمين الجدد.
# وضع Supabase المباشر (بدون VPS Express): جلسة Supabase Auth + جداول PostgREST
# عند تفعيل VITE_USE_SUPABASE=1 + URL + ANON_KEY يُعتبر المشروع تلقائياً في وضع «سيرفر بيانات»
# (لا حاجة لـ VITE_DATA_SOURCE=server منفصلة؛ تجاهل localStorage للديمو).
# VITE_USE_SUPABASE=1
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# انسخ محتوى الملف التالي كاملًا إلى SQL Editor في Supabase وشغّله مرة واحدة:
#   supabase/sql/SUPABASE_SETUP_COPYPASTE.sql

# لتشغيل واجهة بدون باك اند وبدون Supabase فقط ضع: VITE_DATA_SOURCE=local
