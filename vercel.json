{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm ci",
  "build": {
    "env": {
      "NODE_OPTIONS": "--max-old-space-size=6144",
      "VERCEL_FORCE_NO_BUILD_CACHE": "1"
    }
  },
  "rewrites": [
    {
      "source": "/((?!assets/).*)",
      "destination": "/index.html"
    }
  ]
}
