{
  "framework": null,
  "buildCommand": "node scripts/vercel-build.mjs",
  "outputDirectory": "hostinger-dist",
  "installCommand": "npm ci",
  "env": {
    "NODE_OPTIONS": "--max-old-space-size=4096"
  },
  "rewrites": [
    {
      "source": "/((?!assets/).*)",
      "destination": "/index.html"
    }
  ]
}
