# انسخ هذا الملف وسمّه .env (بدون كلمة example)

# --- قاعدة البيانات (سطران لو تستخدم Supabase — انسخهم من الموقع كما في الملف: دليل-ربط-قاعدة-البيانات.md) ---
# السطر الأول: «Connection pooling» أو «Transaction» (غالباً فيه كلمة pooler ورقم 6543)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?sslmode=require"
# السطر الثاني: «Direct connection» (فيه عادة db. و رقم 5432) — نفس كلمة المرور غالباً
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

# لو عندك PostgreSQL عادي على جهازك بدون Supabase: ضع نفس الرابط في السطرين (اتنين زي بعض)

PORT=4000

# توقيع JWT لتسجيل الدخول (أي سلسلة طويلة عشوائية — لا تشاركها)
JWT_SECRET="ضع_سلسلة_عشوائية_32_حرفاً_على_الأقل"
JWT_EXPIRES_IN="7d"

# مفتاح لإضافة موظفين عبر POST /auth/users (مع هيدر X-Admin-Key) — غيّره
ADMIN_API_KEY="ضع_مفتاحاً_سرّياً_طويلاً"

# قائمة مفصولة بفواصل لعناوين الواجهة المسموح لها بالاتصال بالـ API
CORS_ORIGINS="http://localhost:5173,https://your-domain.com"

# عند تشغيل الواجهة على 5173 مع بروكسي Vite → Express، سجّل نفس redirect_uri في Meta بهذا الشكل:
# OAUTH_PUBLIC_BASE_URL=http://localhost:5173

# --- OAuth تكاملات الليدز (نفس المسارات: /api/integrations/auth/.../start|callback) ---
# عنوان الواجهة العام بعد نجاح OAuth (HTTPS في الإنتاج)
# APP_ORIGIN=https://app.your-domain.com
# إن كان الـ API خلف nginx/proxy: فعّل الثقة بالبروكسي
# TRUST_PROXY=1
# إن كان عنوان الـ API العلني يختلف عن Host (نادر): اضبط redirect_uri المسجّل عند المنصات
# OAUTH_PUBLIC_BASE_URL=https://api.your-domain.com
# مسار اختياري لملف التوكنات على السيرفر
# INTEGRATION_OAUTH_TOKEN_PATH=/var/lib/app/integration-tokens.json
# META_APP_ID=  META_APP_SECRET=  GOOGLE_CLIENT_ID=  GOOGLE_CLIENT_SECRET=  LINKEDIN_CLIENT_ID=  LINKEDIN_CLIENT_SECRET=
#
# Google Ads API (سحب Lead Form حقيقي — مطلوب مع توكن google_ads):
# GOOGLE_ADS_DEVELOPER_TOKEN=        # من Google Ads API Center (Test أو Production)
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=      # اختياري: معرّف حساب المدير (MCC) بدون شرطات
# GOOGLE_ADS_CUSTOMER_ID=            # اختياري: إن أردت حساباً واحداً محدداً بدل listAccessibleCustomers
# GOOGLE_ADS_API_VERSION=v17         # اختياري
