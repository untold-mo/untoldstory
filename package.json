{
  "name": "@figma/my-make-file",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "vite build",
    "pack:hostinger": "node scripts/pack-hostinger.mjs",
    "deploy:hostinger": "node scripts/deploy-hostinger-ftp.mjs",
    "dev": "vite",
