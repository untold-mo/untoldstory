    "check:scenarios": "node scripts/run-system-scenarios.mjs",
    "check:accounting": "node scripts/accounting-invariants.mjs",
    "check:system": "npm run check:wiring && npm run check:scenarios && npm run check:accounting",
    "verify": "npm run build && node scripts/verify-workspace.mjs && npm run check:system",
    "db:apply-rls": "node scripts/apply-supabase-rls.mjs",
    "db:apply-pending": "node scripts/apply-db-pending.mjs",
