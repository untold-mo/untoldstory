# انسخ القيم المناسبة إلى .env.local أو api/.env (نفس JWT_SECRET يسمح بربط التوكنات بمستخدم الـ API)
# سجّل نفس redirect_uri في كل منصة (بدون فراغات، نفس البروتوكول والمنفذ):

# OAUTH_PUBLIC_BASE_URL=http://127.0.0.1:8787
# APP_ORIGIN=http://localhost:5173
# JWT_SECRET=...نفس_قيمة_api

# Meta (فيسبوك / إنستجرام / واتساب — نفس META_APP_ID)
# META_APP_ID=
# META_APP_SECRET=
# META_GRAPH_VERSION=v21.0
# META_OAUTH_SCOPES_FACEBOOK=pages_show_list,pages_read_engagement,ads_read,leads_retrieval,business_management
# META_OAUTH_SCOPES_INSTAGRAM=instagram_basic,instagram_manage_insights,pages_show_list,ads_read,business_management
# META_OAUTH_SCOPES_WHATSAPP=whatsapp_business_management,business_management

# Google (يشمل AdWords scope)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_OAUTH_SCOPES=openid https://www.googleapis.com/auth/userinfo.email https://www.googleapis.com/auth/adwords

# LinkedIn
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# LINKEDIN_OAUTH_SCOPES=openid profile email
